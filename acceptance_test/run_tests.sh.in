#!/bin/bash
# SPDX-License-Identifier: BSD-2-Clause
# SPDX-FileCopyrightText: 2026 Przemek Kieszkowski

# Run cucumber-cpp acceptance tests

set -e

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
BUILD_DIR="@CMAKE_BINARY_DIR@"
TEST_BINARY="$BUILD_DIR/acceptance_test/cucumber_tests"

echo "========================================="
echo "Running Cucumber-cpp Acceptance Tests"
echo "========================================="

if [ ! -f "$TEST_BINARY" ]; then
  echo "Error: Test binary not found: $TEST_BINARY"
  echo "Build with: cmake --build . --target cucumber_tests"
  exit 1
fi

# Create test configs directory if it doesn't exist
mkdir -p "$BUILD_DIR/acceptance_test/test_configs"

# Run tests with different output formats
echo ""
echo "Running tests..."
cd "$BUILD_DIR/acceptance_test"

# Pretty console output
"$TEST_BINARY" --format pretty

# Also generate JSON for CI/CD integration
"$TEST_BINARY" --format json --out cucumber_results.json

echo ""
echo "========================================="
echo "Tests completed!"
echo "Results: cucumber_results.json"
echo "========================================="
